#!/usr/bin/env bash
# SOE-CCG — Git Pre-commit Hook
# Valida código antes de cada commit

set -e

# Cores
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

echo -e "${BLUE}🔍 SOE-CCG — Pre-commit validation${NC}"
echo ""

# Obtém arquivos staged
STAGED_PY_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)

if [ -z "$STAGED_PY_FILES" ]; then
    echo -e "${GREEN}✅ Nenhum arquivo Python modificado${NC}"
    exit 0
fi

echo -e "${BLUE}Arquivos Python modificados:${NC}"
echo "$STAGED_PY_FILES" | sed 's/^/  - /'
echo ""

EXIT_CODE=0

# 1. Formatação
echo -e "${BLUE}📋 Verificando formatação...${NC}"
if echo "$STAGED_PY_FILES" | xargs ruff format --check; then
    echo -e "${GREEN}✅ Formatação OK${NC}"
else
    echo -e "${YELLOW}⚠️  Corrigindo formatação automaticamente...${NC}"
    echo "$STAGED_PY_FILES" | xargs ruff format
    echo "$STAGED_PY_FILES" | xargs git add
    echo -e "${GREEN}✅ Formatação corrigida e staged${NC}"
fi
echo ""

# 2. Linting
echo -e "${BLUE}🔍 Executando linting...${NC}"
if echo "$STAGED_PY_FILES" | xargs ruff check; then
    echo -e "${GREEN}✅ Linting OK${NC}"
else
    echo -e "${YELLOW}⚠️  Tentando correção automática...${NC}"
    if echo "$STAGED_PY_FILES" | xargs ruff check --fix; then
        echo "$STAGED_PY_FILES" | xargs git add
        echo -e "${GREEN}✅ Linting corrigido e staged${NC}"
    else
        echo -e "${RED}❌ Alguns problemas não podem ser corrigidos automaticamente${NC}"
        EXIT_CODE=1
    fi
fi
echo ""

# 3. Type checking (opcional, pode ser lento)
# Descomente se quiser type checking no pre-commit
# echo -e "${BLUE}🔍 Verificando tipos...${NC}"
# if echo "$STAGED_PY_FILES" | xargs mypy --strict; then
#     echo -e "${GREEN}✅ Tipos OK${NC}"
# else
#     echo -e "${RED}❌ Erros de tipo encontrados${NC}"
#     EXIT_CODE=1
# fi
# echo ""

# Resultado
if [ $EXIT_CODE -eq 0 ]; then
    echo -e "${GREEN}✅ Pre-commit validation passou${NC}"
    echo ""
else
    echo -e "${RED}❌ Pre-commit validation falhou${NC}"
    echo -e "${YELLOW}Corrija os problemas e tente novamente${NC}"
    echo ""
fi

exit $EXIT_CODE
